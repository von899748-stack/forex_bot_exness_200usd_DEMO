# MT5/Exness Configuration
MT5_LOGIN=your_account_number
MT5_PASSWORD=your_password
MT5_SERVER=Exness-Demo
MT5_PATH=/path/to/metatrader5.exe

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Database
TIMESCALEDB_HOST=localhost
TIMESCALEDB_PORT=5432
TIMESCALEDB_DB=forex_bot
TIMESCALEDB_USER=postgres
TIMESCALEDB_PASSWORD=postgres

# RabbitMQ (optional)
RABBITMQ_URL=amqp://localhost:5672/
USE_RABBITMQ=False

# Trading Parameters
TOTAL_CAPITAL=200
MAX_AGENTS=5
RISK_BASE=0.01
DYNAMIC_RISK=True
MAX_RISK=0.02
MIN_RISK=0.005
TRADING_START=7
TRADING_END=22
MAX_CONSECUTIVE_LOSSES=3
ENABLE_NOISE_FILTER=True

# Broker Mode
BROKER_MODE=demo  # 'demo' or 'live'

# Logging
LOG_LEVEL=INFO
LOG_ROTATION=1 day
LOG_RETENTION=7 days

# Dashboard
DASHBOARD_PORT=8501
